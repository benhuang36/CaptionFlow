    "Couldn't start: %@\nGrant access in System Settings → Privacy & Security → Screen Recording, then try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't start: %@\nGrant access in System Settings → Privacy & Security → Screen Recording, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "起動できません:%@\n「システム設定 → プライバシーとセキュリティ → 画面収録」で許可してから再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法启动:%@\n请到“系统设置 → 隐私与安全性 → 屏幕录制”授权后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法啟動:%@\n請到「系統設定 → 隱私權與安全性 → 螢幕錄製」授權後再試。"
          }
        }
      }
    },
